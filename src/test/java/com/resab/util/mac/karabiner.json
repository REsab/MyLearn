                    {
                        "description": "shift+fn toggles fn key  mode between 'fullControlStrip' and 'functionKeys'",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "fn",
                                    "modifiers": { "mandatory": ["shift"] }
                                },
                                "to": [{ "shell_command": "if [[ $(defaults read .GlobalPreferences com.apple.keyboard.fnState) == '1' ]]; then  defaults write .GlobalPreferences com.apple.keyboard.fnState -bool no; else defaults write .GlobalPreferences com.apple.keyboard.fnState -bool yes; fi && pkill ControlStrip" }],
                                "type": "basic"
                            }
                        ]
